
import os
import glob

# Directories
CLEANED_DIR = "/uufs/chpc.utah.edu/common/home/kapheim-group2/priscila/bimp_MAH_rnaseq/bombus_project/cleaned_data/"
ALIGNMENT_DIR = "/uufs/chpc.utah.edu/common/home/kapheim-group2/priscila/bimp_MAH_rnaseq/bombus_project/alignment/"
REFERENCE_DIR = "/uufs/chpc.utah.edu/common/home/kapheim-group2/priscila/bimp_MAH_rnaseq/bombus_project/reference_genome/"
COUNTS_DIR = "/uufs/chpc.utah.edu/common/home/kapheim-group2/priscila/bimp_MAH_rnaseq/bombus_project/quantification/"

# Reference genome and annotation
REFERENCE_GENOME = REFERENCE_DIR + "Bombus_impatiens_BIMP_2_2_genomic.fa"
GTF_FILE = REFERENCE_DIR + "Bombus_impatiens_BIMP_2_2_genomic.gtf"

# Get all samples from the cleaned data directory
SAMPLES, = glob_wildcards(CLEANED_DIR + "{sample}_L004_R1_paired.fastq.gz")

# Define the workflow
rule all:
    input:
        expand(COUNTS_DIR + "{sample}.genes.results", sample=SAMPLES), \
        REFERENCE_DIR + "Index.done", \
        REFERENCE_DIR + "ReferenceRSEM.done", \
        expand(ALIGNMENT_DIR + "{sample}.Aligned.toTranscriptome.out.bam", sample=SAMPLES)

# Rule to index the reference genome with STAR
rule index_genome:
    input:
        reference = REFERENCE_GENOME,
        gtf = GTF_FILE
    output:
        REFERENCE_DIR + "Index.done"
    resources: mem_mb = 12000
    params:
        cpu = 4,
        genomeDir = REFERENCE_DIR
    shell:
        """
        /uufs/chpc.utah.edu/common/home/u6021652/STAR-2.7.11b/source/STAR --runMode genomeGenerate \
             --genomeDir {params.genomeDir} \
             --genomeFastaFiles {input.reference} \
             --sjdbGTFfile {input.gtf} \
             --runThreadN {params.cpu} \
             --sjdbOverhang 143
        touch {output}
        """

# Rule to align reads with STAR
rule star_align:
    input:
        r1 = CLEANED_DIR + "{sample}_L004_R1_paired.fastq.gz",
        r2 = CLEANED_DIR + "{sample}_L004_R2_paired.fastq.gz",
        index_done = REFERENCE_DIR + "Index.done"
    output:
        bam = ALIGNMENT_DIR + "{sample}.Aligned.toTranscriptome.out.bam"
    resources: mem_mb = 24000
    params:
        cpu = 8,
        genomeDir = REFERENCE_DIR
    shell:
        """
        mkdir -p {ALIGNMENT_DIR}
        /uufs/chpc.utah.edu/common/home/u6021652/STAR-2.7.11b/source/STAR --runThreadN {params.cpu} \
             --genomeDir {params.genomeDir} \
             --readFilesIn {input.r1} {input.r2} \
             --readFilesCommand zcat \
             --outFileNamePrefix {ALIGNMENT_DIR}{wildcards.sample}. \
             --outSAMtype BAM Unsorted \
             --quantMode TranscriptomeSAM
        """

# Rule to prepare RSEM reference
rule rsem_reference:
    input:
        reference = REFERENCE_DIR,
        gtf = GTF_FILE
    output:
        REFERENCE_DIR + "ReferenceRSEM.done"
    resources:
        mem_mb = 12000
    params:
        cpu = 4,
        rsem_reference = REFERENCE_DIR + "Bombus_impatiens_BIMP_2_2_genomic.fa"
    shell:
        """
        module load rsem/1.3.0
        rsem-prepare-reference --gtf {input.gtf} {input.reference} {params.rsem_reference}
        touch {output}
        """

# Rule to generate read counts with RSEM
rule rsem_calculate_expression:
    input:
        bam = ALIGNMENT_DIR + "{sample}.Aligned.toTranscriptome.out.bam"
    output:
        counts = COUNTS_DIR + "{sample}.genes.results"
    resources: mem_mb = 24000
    params:
        cpu = 8,
        rsem_reference = REFERENCE_DIR + "Bombus_impatiens_BIMP_2_2_genomic.fa"
    shell:
        """
        module load rsem/1.3.0
        mkdir -p {COUNTS_DIR}
        cd {COUNTS_DIR}
        rsem-calculate-expression --paired-end --strandedness reverse --bam {input.bam} {params.rsem_reference} {wildcards.sample}
        """

